// Typechecks the audit engine (the only TypeScript in this repo) — run via
// `npm run typecheck`. The engine is bundled by esbuild and executed as ESM
// under Node, so: ES2022 target with import.meta, Bundler resolution for the
// `.ts`-extension imports (allowImportingTsExtensions requires noEmit), and
// non-strict to keep the gate green while still catching shape drift.
{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": false,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "types": ["node"]
  },
  "include": ["plugins/awos/skills/ai-readiness-audit/**/*.ts"]
}
