{
  "name": "@provectusinc/awos",
  "version": "0.0.0-develop",
  "description": "This framework outlines a structured approach to leveraging Large Language Models (LLMs) for high-quality code generation, moving beyond basic prompting to a spec-driven development methodology.",
  "repository": {
    "type": "git",
    "url": "https://github.com/provectus/awos.git"
  },
  "main": "index.js",
  "scripts": {
    "test": "node --test 'tests/**/*.test.js'",
    "test:lint": "node --test tests/lint-prompts.test.js",
    "test:installer": "node --test 'tests/installer/*.test.js'",
    "test:fixtures": "node --test tests/fixtures.test.js",
    "test:coverage": "node --test --experimental-test-coverage --test-coverage-include='src/**/*.js' --test-coverage-exclude='tests/**' --test-coverage-exclude='src/index.js' 'tests/**/*.test.js'",
    "test:coverage:gate": "node --test --experimental-test-coverage --test-coverage-include='src/**/*.js' --test-coverage-exclude='tests/**' --test-coverage-exclude='src/index.js' --test-coverage-lines=${COVERAGE_LINES:-85} --test-coverage-functions=${COVERAGE_FUNCTIONS:-95} --test-coverage-branches=${COVERAGE_BRANCHES:-80} 'tests/**/*.test.js'"
  },
  "keywords": [],
  "author": "Provectus Inc.",
  "license": "MIT",
  "bin": "./index.js"
}
